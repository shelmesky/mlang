namespace main

use "format"

function main() -> int {
    let j: int = 0
    let k: int = 0

    for j=0; j<3; j=j+1 {
        printf("outer loop: %d\n", j)

        for k=0; k<3; k=k+1 {
            printf("inner loop: %d\n", k)
        }
    }

    let i: int = 0

    for i=0; i<10; i=i+1 {
        if i > 6 {
            break
        }
        printf("i value: %d\n", i)
    }

    let m: int = 0
    for m=0; m<10; m=m+1 {
        if m == 4 {
            continue
        }
        printf("m value: %d\n", m)
    }

    return 0
}
